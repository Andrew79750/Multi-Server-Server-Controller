{
  "name": "ess-server-controller",
  "version": "1.0.0",
  "description": "ESS Server Controller desktop dashboard",
  "main": "main.js",
  "author": "ESS",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win --x64",
    "pack:app": "electron-builder --dir --win --x64",
    "prepare-payload": "node scripts/prepare-payload.js",
    "installer:install": "cd installer && npm install",
    "installer:dev": "cd installer && npm start",
    "installer:build": "cd installer && npm run dist",
    "build:full": "npm run pack:app && npm run prepare-payload && npm run installer:build"
  },
  "dependencies": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ess.servercontroller",
    "productName": "ESS Server Controller",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "backend/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ESS Server Controller",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "installerHeader": "src/assets/installer-header.bmp",
      "installerHeaderIcon": "src/assets/icon.ico",
      "installerSidebar": "src/assets/installer-sidebar.bmp",
      "uninstallerSidebar": "src/assets/uninstaller-sidebar.bmp",
      "artifactName": "ESS-Server-Controller-Setup-${version}.${ext}",
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Andrew79750",
        "repo": "Multi-Server-Server-Controller"
      }
    ]
  }
}
