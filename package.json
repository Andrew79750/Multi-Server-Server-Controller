{
  "name": "ess-server-controller",
  "version": "1.0.0",
  "description": "ESS Server Controller desktop dashboard",
  "main": "main.js",
  "author": "ESS",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win --x64",
    "pack:app": "electron-builder --dir --win --x64",
    "installer:install": "cd installer && npm install",
    "installer:dev": "cd installer && npm start",
    "installer:build": "cd installer && npm run dist",
    "build:full": "npm run dist && npm run installer:build"
  },
  "dependencies": {
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.ess.servercontroller",
    "productName": "ESS Server Controller",
    "asar": false,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "backend/**/*",
      "config/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/icon.ico",
      "artifactName": "ESS-Server-Controller-App-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Andrew79750",
        "repo": "Multi-Server-Server-Controller"
      }
    ]
  }
}
